#!/bin/sh

. /lib/blue-merle/functions.sh
. /lib/functions/gl_util.sh

rm -f /tmp/blue-merle-stage1

mcu_send_message "Switch pulled.  Continuing..."
sleep 1
sim_switch on

leak=0

until gl_modem AT AT+CFUN=0 | grep -q OK
do
	mcu_send_message "Resetting modem state... Please be patient."
	sleep 1
done

until gl_modem AT AT+CFUN=4 | grep -q OK
do
	leak=1
	mcu_send_message "Re-securing modem... Please wait."
	sleep 1
done

if [[ $leak -eq 1 ]]; then
	mcu_send_message "Reset completed successfully."
	sleep 3
fi

sleep 1

new_imsi=$(READ_IMSI)

if [[ "$old_imsi" == "$new_imsi" ]]; then
	mcu_send_message "Device state    confirmed.      Preparing new   device identity."
	sleep 3
else
    # ERROR: A different SIM was detected. The user must restart.
    # We send two messages to clearly explain the error and the correct procedure.
    mcu_send_message "ERROR: New SIM  detected early. Please restart  the process."
    sleep 5

    mcu_send_message "The new SIM must only be inserted AFTER the device is fully shut down."
    sleep 6 # A bit longer so the user has time to read the instruction.
    
    exit 1
fi

old_imei=$(READ_IMEI)
mcu_send_message "Generating new  device identity (IMEI)..."
timeout 15 python3 /lib/blue-merle/imei_generate.py -r

new_imei=$(READ_IMEI)


if [[ "$old_imei" == "$new_imei" ]]; then
	mcu_send_message "WARNING:        Old IMEI equals new IMEI."
	sleep 3
else
	#FIXME old_imei is not the real old imei because in stage1 its already generated a new one
	# so this is a bit missleading but for the prupose of visualy see the change it works
	mcu_send_message  "IMEI Old:...... ${old_imei}IMEI New:...... ${new_imei}"
	sleep 5
	mkdir -p /tmp/modem.1-1.2
	echo "$new_imei" > /tmp/modem.1-1.2/modem-imei
	# prevent imei leak via the LPA
	echo "$new_imei" > /root/esim/imei
	shred -u /root/esim/log.txt # unclear if the imei/imsi will be loged here, just a precaution
fi

logger -p notice -t blue-merle-toggle "Changed IMEI from ${old_imei} to ${new_imei}"


mcu_send_message "Process complete. The device will now shut down."
sleep 3
mcu_send_message "For best privacy, change your       location before booting again."
sleep 5
mcu_send_message "IMPORTANT: Insert the new SIM     ONLY AFTER the  device is off."
sleep 5


i=5
until  [[ $i -eq 0 ]]
do
        i=$((i-1))
        mcu_send_message "Shutting down... ($i)"
        sleep 1
done

logger -p notice -t blue-merle-toggle "Finished with Stage 2"

# Note: calling /sbin/poweroff directly results in the device rebooting into a broken state
echo '{ "poweroff": "1" }' >/dev/ttyS0
